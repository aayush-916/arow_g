# Netlify headers — keep the service worker and manifest fresh so PWA updates
# always take effect (a stale cached sw.js can otherwise block its own update).
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache
